# YouTube Data API v3 (БЕСПЛАТНЫЙ, 10K запросов/день)
# Получи: console.cloud.google.com -> APIs -> YouTube Data API v3 -> Credentials
YOUTUBE_API_KEY=your_youtube_api_key_here

# Anthropic / Claude API (для генератора идей)
# Получи: console.anthropic.com -> API Keys
ANTHROPIC_API_KEY=your_anthropic_api_key_here
