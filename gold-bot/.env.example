# Скопируйте этот файл в .env и впишите свои значения. .env в git НЕ коммитится
# (см. .gitignore) - настоящие ключи никогда не должны попасть в репозиторий.
#
# Как получить ключи - см. README.md, раздел "Как получить API-ключи Bybit".

BYBIT_API_KEY=your_api_key_here
BYBIT_API_SECRET=your_api_secret_here

# Приоритет: если BYBIT_DEMO=true, он побеждает BYBIT_TESTNET (см. bot/bybit_client.py).
#
# BYBIT_DEMO=true  -> Demo Trading: виртуальный баланс, но РЕАЛЬНЫЕ рыночные
#                      данные Bybit mainnet - рекомендуется для этапа 4 (демо-торговля),
#                      честнее классического testnet.
# BYBIT_TESTNET=true -> отдельная тестовая сеть Bybit, СВОЯ нереалистичная история
#                        цен и почти нет ликвидности - годится только для проверки,
#                        что код в принципе умеет отправлять ордера, не для оценки стратегии.
# Оба false -> РЕАЛЬНЫЙ счёт с настоящими деньгами. Требует явного подтверждения
#              владельца проекта в чате с Claude, см. config.py -> IS_DEMO_ONLY.
BYBIT_DEMO=true
BYBIT_TESTNET=false
